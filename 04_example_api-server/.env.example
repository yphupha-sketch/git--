# PostgreSQL connection string from Supabase
# Found in: Supabase dashboard > Project Settings > Database > Connection string (URI mode)
SUPABASE_URI=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# MongoDB connection string from Atlas
# Found in: Atlas dashboard > Database > Connect > Drivers
MONGO_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/[database]?retryWrites=true&w=majority

# Optional — defaults to 3000
PORT=3000
